---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'projects'>['data'];

const { title, description, pubDate, updatedDate, heroImage, siteUrl, repoUrl, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				display: flex;
				flex-direction: column;
				gap: 0.5em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.project-links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75em;
				justify-content: center;
				margin: 1em 0;
			}
			.project-links a {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.45em 1em;
				border-radius: 6px;
				font-size: 0.9em;
				font-weight: 600;
				text-decoration: none;
				transition: opacity 0.15s ease;
			}
			.project-links a:hover {
				opacity: 0.8;
			}
			.link-site {
				background: var(--accent);
				color: white;
			}
			.link-repo {
				background: rgb(var(--gray-dark));
				color: white;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin: 0.75em 0 0;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 4px;
				padding: 0.2em 0.6em;
				font-size: 0.8em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image src={heroImage} width={Math.min(heroImage.width, 720)} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							{pubDate && <FormattedDate date={pubDate} />}
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{(siteUrl || repoUrl) && (
							<div class="project-links">
								{siteUrl && (
									<a href={siteUrl} target="_blank" rel="noopener noreferrer" class="link-site">
										<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
											<polyline points="15 3 21 3 21 9" />
											<line x1="10" y1="14" x2="21" y2="3" />
										</svg>
										View Site
									</a>
								)}
								{repoUrl && (
									<a href={repoUrl} target="_blank" rel="noopener noreferrer" class="link-repo">
										<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor">
											<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
										</svg>
										GitHub
									</a>
								)}
							</div>
						)}
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => <span class="tag">{tag}</span>)}
							</div>
						)}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
